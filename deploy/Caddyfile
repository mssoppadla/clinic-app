# Routing (served behind the front proxy that terminates TLS for tovaitech.in):
#   /                         -> Tovaitech company landing (separate stack)
#   /appointments(/)          -> onboarding landing / clinic registration (appointments.html)
#   /appointments/onboard     -> same registration page (mock's onboarding entry)
#   /appointments/onboard-admin -> provider go-live approvals (onboard-admin.html; auth Phase 2)
#   /appointments/assets/*    -> clinic-app static assets (e.g. styles/app.css)
#   /appointments/<slug>/admin -> THAT clinic's integrations admin (admin.html; per-clinic creds)
#   /appointments/<slug>/slots -> THAT clinic's slot management (slots.html)
#   /appointments/<slug>/users -> THAT clinic's team management (users.html)
#   /appointments/<clinic-slug> -> patient booking app (index.html; slug read from the path)
#   (/admin is intentionally NOT handled here — reserved for the company site's future admin)
#   /api/*                    -> FastAPI (unstripped; app serves routes under /api/v1 via root_path)
:80 {
	handle /api/* {
		reverse_proxy api:8000
	}
	# Clinic-app's own static assets. MUST sit under /appointments/* because the front
	# proxy only routes /appointments/*, /admin*, /api/* to this stack; the root /styles/*
	# path belongs to the separate company-site stack. handle_path strips the prefix, so
	# /appointments/assets/styles/app.css -> /srv/web/styles/app.css.
	handle_path /appointments/assets/* {
		root * /srv/web
		file_server
	}
	# Onboarding landing + registration. Reserved (non-slug) paths under /appointments.
	@onboarding path /appointments /appointments/ /appointments/onboard /appointments/onboard/
	handle @onboarding {
		root * /srv/web
		rewrite * /appointments.html
		file_server
	}
	# Onboarding: add doctors & slots.
	@doctors path /appointments/onboard/doctors /appointments/onboard/doctors/
	handle @doctors {
		root * /srv/web
		rewrite * /doctors.html
		file_server
	}
	# Appearance configurator (brand colours/text/logo + embed snippet).
	@customize path /appointments/onboard/customize /appointments/onboard/customize/
	handle @customize {
		root * /srv/web
		rewrite * /customize.html
		file_server
	}
	# Provider go-live approvals (unlinked; auth wired in Phase 2).
	@approvals path /appointments/onboard-admin /appointments/onboard-admin/
	handle @approvals {
		root * /srv/web
		rewrite * /onboard-admin.html
		file_server
	}
	# Clinic integrations admin — under /appointments/* like the other admin pages.
	@adminpage path /appointments/admin /appointments/admin/ /appointments/admin.html
	handle @adminpage {
		root * /srv/web
		rewrite * /admin.html
		file_server
	}
	# Team & user management (clinic_admin / superadmin).
	@userspage path /appointments/users /appointments/users/
	handle @userspage {
		root * /srv/web
		rewrite * /users.html
		file_server
	}
	# Appointment slot management (clinic staff).
	@slotspage path /appointments/slots /appointments/slots/
	handle @slotspage {
		root * /srv/web
		rewrite * /slots.html
		file_server
	}
	# Clinic-scoped staff pages: /appointments/<slug>/{admin,slots,users}. Each hospital has its
	# own staff area; the page reads the slug and the API authorizes the caller against THAT clinic.
	# These regexp matchers must precede the patient catch-all below (handle = first match wins).
	@clinicadmin path_regexp ^/appointments/[^/]+/admin/?$
	handle @clinicadmin {
		root * /srv/web
		rewrite * /admin.html
		file_server
	}
	@clinicslots path_regexp ^/appointments/[^/]+/slots/?$
	handle @clinicslots {
		root * /srv/web
		rewrite * /slots.html
		file_server
	}
	@clinicusers path_regexp ^/appointments/[^/]+/users/?$
	handle @clinicusers {
		root * /srv/web
		rewrite * /users.html
		file_server
	}
	@clinicdoctor path_regexp ^/appointments/[^/]+/doctor/?$
	handle @clinicdoctor {
		root * /srv/web
		rewrite * /doctor.html
		file_server
	}
	# Everything else under /appointments/<slug> is a clinic's patient booking page.
	handle /appointments/* {
		root * /srv/web
		rewrite * /index.html
		file_server
	}
	# "/" belongs to the company site (separate stack). Any stray hit here -> company landing.
	handle {
		redir https://tovaitech.in/ 302
	}
}
