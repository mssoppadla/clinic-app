# Copy to .env and fill. NEVER commit .env (see .gitignore). No secrets in code.
APP_ENV=local
APP_LOG_LEVEL=INFO
# Postgres (compose)
POSTGRES_USER=clinic
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=clinic
# App DB url is built from the above in compose; override for bare-metal if needed
# APP_DATABASE_URL=postgresql+psycopg://clinic:change-me-strong@localhost:5432/clinic
# CORS only needed when web is served from a different origin (local dev)
APP_CORS_ORIGINS=http://localhost:8080
# Queue/ETA tunables (no hardcoding)
APP_AVG_CONSULT_MINUTES=6
APP_DEFAULT_SESSION_CAPACITY=40
# Languages: English always present; add others (Malayalam) after
APP_DEFAULT_LANGUAGES=en,ml
# --- WhatsApp Cloud API (DIRECT, no BSP) : stub now, switch to live with your creds ---
APP_WHATSAPP_MODE=stub
APP_WHATSAPP_TOKEN=
APP_WHATSAPP_PHONE_NUMBER_ID=
# --- Bhashini (Malayalam) : stub now, switch to live with your creds ---
APP_BHASHINI_MODE=stub
APP_BHASHINI_BASE_URL=
APP_BHASHINI_API_KEY=
APP_BHASHINI_USER_ID=
